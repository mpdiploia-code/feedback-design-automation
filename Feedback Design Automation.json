      "parameters": {
        "jsCode": "const text = $input.first().json.content[0].text;\n\nconst jsonMatch = text.match(/```json\\n([\\s\\S]*?)\\n```/);\nconst jsonString = jsonMatch[1];\nconst items = JSON.parse(jsonString);\n\nconst labelMap = {\n  'Alta': '6a5160bf08de2903d3756bc1',\n  'Media': '6a5160cd6da489f94f048eee',\n  'Baja': '6a5161014775737140fa3d58',\n  'Mínima': '6a516126cb4e14564058465e',\n  'Revisar': '6a516135c91c5a96aa06db81'\n};\n\nreturn items.map(item => ({ \n  json: {\n    ...item,\n    labelId: labelMap[item.prioridad] || ''\n  }\n}));"
      },
